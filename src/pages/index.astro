---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Card from '../components/Card.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="es">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <style>
            :root {
                --bg-color: #f8f9fa;
                --text-color: #1a1a1a;
                --accent: #8a8a68;
                /* Colores Bola 3D Claro */
                --orb-1: #ffffff;
                --orb-2: #d4d4b1;
                --orb-3: #a0a078;
                --orb-shadow: rgba(0, 0, 0, 0.1);
                --glass: rgba(255, 255, 255, 0.6);
            }

            :root.dark {
                --bg-color: #0f0a1a;
                --text-color: #e0d0ff;
                --accent: #bc9aff;
                /* Colores Bola Neón 3D */
                --orb-1: #b085ff;
                --orb-2: #4a3080;
                --orb-3: #1a0b2e;
                --orb-shadow: rgba(188, 154, 255, 0.4);
                --glass: rgba(20, 15, 35, 0.8);
            }

            html, body {
                background-color: var(--bg-color);
                transition: background-color 0.5s ease;
                margin: 0;
                padding: 0;
                min-height: 100%;
            }

            body {
                color: var(--text-color);
                font-family: system-ui, sans-serif;
                overflow-x: hidden;
            }

            .theme-toggle {
                position: fixed;
                top: 100px;
                right: 20px;
                z-index: 100;
                padding: 10px 18px;
                border-radius: 30px;
                border: 1px solid var(--accent);
                background: var(--glass);
                color: var(--text-color);
                cursor: pointer;
                backdrop-filter: blur(10px);
                font-weight: bold;
                box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            }

            /* Contenedor Hero */
            .hero-container {
                position: relative;
                height: 100vh;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                text-align: center;
            }

            .content-hero {
                position: relative;
                z-index: 5; /* Asegura que el texto esté por ENCIMA de la bola */
                pointer-events: none;
            }

            h1 {
                font-size: clamp(3rem, 12vw, 7rem);
                font-weight: 900;
                margin: 0;
                color: var(--text-color);
                line-height: 1;
            }

            .subtitle {
                letter-spacing: 0.4em;
                color: var(--accent);
                font-weight: 700;
                margin-top: 1rem;
                text-transform: uppercase;
            }

            /* La Bola (Fondo) */
            .orb-wrapper {
                position: fixed;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                z-index: 1; /* Detrás de todo el contenido */
                pointer-events: none;
            }

            .light-orb {
                width: 320px;
                height: 320px;
                border-radius: 50%;
                /* Efecto 3D con iluminación direccional */
                background: radial-gradient(circle at 30% 30%, var(--orb-1) 0%, var(--orb-2) 40%, var(--orb-3) 100%);
                /* Glow / Neón */
                box-shadow: 
                    inset -10px -10px 30px rgba(0,0,0,0.2),
                    0 0 60px var(--orb-shadow);
                will-change: transform;
            }

            :root.dark .light-orb {
                /* Refuerzo de neón en modo oscuro */
                box-shadow: 
                    0 0 40px var(--accent),
                    0 0 100px var(--orb-2);
            }

            .floating-section {
                position: relative;
                z-index: 10;
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
                max-width: 1100px;
                margin: 0 auto;
                gap: 30px;
                padding: 100px 20px;
            }

            main {
                position: relative;
                z-index: 10;
                padding: 100px 20px;
                text-align: center;
            }
        </style>
    </head>
    <body>
        <button class="theme-toggle" id="theme-btn">🌓 SWAP MODE</button>
        
        <Header />
        
        <section class="hero-container">
            <div class="content-hero">
                <h1 id="title">¡Hola! Soy Leandro</h1>
                <p class="subtitle" id="subtitle">Bienvenidos a mi proyecto personal.</p>
            </div>

            <div class="orb-wrapper">
                <div class="light-orb" id="dynamic-orb"></div>
            </div>
        </section>

        <section class="floating-section">
            <Card title="✨ Post recomendado 1" body="Blablablabla." />
            <Card title="🌀 Post recomendado 2" body="Blablablabla." />
            <Card title="🍃 Post recomendado 3" body="Blablablabla." />
        </section>

        <main>
            <p>Página en construcción. Se realizan cambios constantemente.</p>
        </main>

        <Footer />

        <script>
            const orb = document.getElementById('dynamic-orb');
            const title = document.getElementById('title');
            const subtitle = document.getElementById('subtitle');
            
            window.addEventListener('scroll', () => {
                const scrolled = window.scrollY;
                
                if (orb) {
                    // Expansión masiva para cubrir el fondo
                    const scale = 1 + (scrolled * 0.02); 
                    const moveY = scrolled * 0.1; // Pequeño movimiento de paralaje
                    orb.style.transform = `scale(${scale}) translateY(${moveY}px)`;
                    
                    // Suavizado de la bola al expandirse
                    if (scrolled > 300) {
                        orb.style.opacity = `${1 - (scrolled - 300) / 1000}`;
                    } else {
                        orb.style.opacity = '1';
                    }
                }
                
                if (title) {
                    title.style.opacity = `${1 - scrolled / 500}`;
                    title.style.filter = `blur(${scrolled / 100}px)`;
                }
            });

            // Dark Mode Logic
            const btn = document.getElementById('theme-btn');
            const html = document.documentElement;

            const updateTheme = () => {
                const isDark = html.classList.contains('dark');
                localStorage.setItem('theme', isDark ? 'dark' : 'light');
            };

            btn?.addEventListener('click', () => {
                html.classList.toggle('dark');
                updateTheme();
            });

            if (localStorage.getItem('theme') === 'dark') {
                html.classList.add('dark');
            }
        </script>
    </body>
</html>